[618.8741869926453,"o","\u001b[?2004l\u001b[?2004h> "]
[623.767740726471,"o","import getRandomNumber from '../utils.js';"]
[623.7683336734772,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.7705931663513,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[623.775785446167,"o","\u001b[?2004l\u001b[?2004h\n> function generateProgression() {\r"]
[623.7801270484924,"o","\n>   const length = getRandomNumber(5, 10); // Длина прогрессии от 5 до 10"]
[623.7806372642517,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.7879583835602,"o","\u001b[?2004l\u001b[?2004h\n>   const start = getRandomNumber(1, 50);  // Начальное число\r"]
[623.7887699604034,"o","\u001b[?2004l\u001b[?2004h\n>   const step = getRandomNumber(2, 10);   // Шаг прогрессии\r"]
[623.7930445671082,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[623.7945680618286,"o","\n>   // Создаем массив прогрессии"]
[623.7947676181793,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.809690952301,"o","\n>\u001b[1C"]
[623.8202109336853,"o","\u001b[?2004l\u001b[?2004h  const progression = [];\r"]
[623.822256565094,"o","\u001b[?2004l\u001b[?2004h\n>   for (let i = 0; i < length; i++) {\r"]
[623.8229856491089,"o","\u001b[?2004l\u001b[?2004h\n>     progression.push(start + i * step);\r"]
[623.823563337326,"o","\u001b[?2004l\u001b[?2004h\n>   }\r"]
[623.8255405426025,"o","\n>\u001b[3C"]
[623.8420791625977,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.8421664237976,"o","\n"]
[623.8575398921967,"o",">\u001b[1C"]
[623.8619673252106,"o","\u001b[?2004l\u001b[?2004h  // Выбираем случайную позицию для скрытого элемента\r"]
[623.8660535812378,"o","\u001b[?2004l\u001b[?2004h\n>   const hiddenIndex = getRandomNumber(0, length - 1);\r"]
[623.8666133880615,"o","\u001b[?2004l\u001b[?2004h\n>   const correctAnswer = String(progression[hiddenIndex]);\r"]
[623.8691046237946,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[623.8717074394226,"o","\u001b[?2004l\u001b[?2004h\n>   // Заменяем элемент на \"..\"\r"]
[623.8725318908691,"o","\u001b[?2004l\u001b[?2004h\n>   progression[hiddenIndex] = '..';\r"]
[623.8735983371735,"o","\n>\u001b[3C"]
[623.8737688064575,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.8802437782288,"o","\u001b[?2004l\u001b[?2004h\n>   // Формируем вопрос (объединяем через пробел)\r"]
[623.8811688423157,"o","\u001b[?2004l\u001b[?2004h\n>   const question = progression.join(' ');\r"]
[623.8825511932373,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[623.8842468261719,"o","\u001b[?2004l\u001b[?2004h\n>   return {\r"]
[623.8865303993225,"o","\u001b[?2004l\u001b[?2004h\n>     question: question,\r"]
[623.88756108284,"o","\u001b[?2004l\u001b[?2004h\n>     correctAnswer: correctAnswer,\r"]
[623.8883147239685,"o","\u001b[?2004l\u001b[?2004h\n>   };\r"]
[623.8888092041016,"o","\u001b[?2004l\u001b[?2004h\n> }\r"]
[623.8895332813263,"o","\n>\u001b[1C"]
[623.8896570205688,"o","\u001b[?2004l\u001b[?2004h\r"]
[623.8922502994537,"o","\u001b[?2004l\u001b[?2004h\n> const gameRules = 'What number is missing in the progression?';\r"]
[623.8940076828003,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[623.895467042923,"o","\u001b[?2004l\u001b[?2004h\n> export default {\r"]
[623.8979501724243,"o","\u001b[?2004l\u001b[?2004h\n>   rules: gameRules,\r"]
[623.8987324237823,"o","\u001b[?2004l\u001b[?2004h\n>   generateRound: generateProgression,\r"]
[623.9055750370026,"o","\n> };"]

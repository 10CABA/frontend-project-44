[1458.9651310443878,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[1458.9665184020996,"o","\u001b[?2004l\u001b[?2004h\n> function isPrime(num) {\r"]
[1458.9676966667175,"o","\u001b[?2004l\u001b[?2004h\n>   if (num < 2) {\r"]
[1458.968374967575,"o","\u001b[?2004l\u001b[?2004h\n>     return false;\r"]
[1458.9694435596466,"o","\u001b[?2004l\u001b[?2004h\n>   }\r"]
[1458.973145723343,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[1458.9752089977264,"o","\u001b[?2004l\u001b[?2004h\n>   for (let i = 2; i <= Math.sqrt(num); i++) {\r"]
[1458.9765119552612,"o","\u001b[?2004l\u001b[?2004h\n>     if (num % i === 0) {\r"]
[1458.9773654937744,"o","\u001b[?2004l\u001b[?2004h\n>       return false;\r"]
[1458.9781720638275,"o","\u001b[?2004l\u001b[?2004h\n>     }\r"]
[1458.9791388511658,"o","\u001b[?2004l\u001b[?2004h\n>   }\r"]
[1458.981287240982,"o","\u001b[?2004l\u001b[?2004h\n>\r"]
[1458.9819049835205,"o","\u001b[?2004l\u001b[?2004h\n>   return true;\r"]

[1458.9907655715942,"o","\u001b[?2004h\u001b[?2004l\u001b[?2004h\n>   const randomNumber = getRandomNumber(1, 100);\r"]
[1458.9915487766266,"o","\u001b[?2004l\u001b[?2004h\n>   const correctAnswer = isPrime(randomNumber) ? 'yes' : 'no';\r"]

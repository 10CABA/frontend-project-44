[348.5789668560028,"o","\u001b[?2004l\u001b[?2004h> "]
[353.48841094970703,"o","import getRandomNumber from '../utils.js';"]
[353.4890446662903,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.4912738800049,"o","\u001b[?2004l\u001b[?2004h\r\n> function generateProgression() {"]
[353.49645948410034,"o","\u001b[?2004l\u001b[?2004h\r\n>   const length = getRandomNumber(5, 10); // Длина прогрессии от 5 до 10"]
[353.5009467601776,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.5034201145172,"o","  const start = getRandomNumber(1, 50);  // Начальное число"]
[353.5086226463318,"o","\u001b[?2004l\u001b[?2004h\r\n>   const step = getRandomNumber(2, 10);   // Шаг прогрессии"]
[353.5094382762909,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[353.51372146606445,"o","\u001b[?2004l\u001b[?2004h\r\n>   // Создаем массив прогрессии"]
[353.5153455734253,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.5387227535248,"o","  const progression = [];"]
[353.5408799648285,"o","\u001b[?2004l\u001b[?2004h\r\n>   for (let i = 0; i < length; i++) {"]
[353.5429639816284,"o","\u001b[?2004l\u001b[?2004h\r\n>     progression.push(start + i * step);"]
[353.5436818599701,"o","\u001b[?2004l\u001b[?2004h\r\n>   }"]
[353.5442912578583,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[353.5627157688141,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.57953333854675,"o","  // Выбираем случайную позицию для скрытого элемента"]
[353.582674741745,"o","\u001b[?2004l\u001b[?2004h\r\n>   const hiddenIndex = getRandomNumber(0, length - 1);"]
[353.58673644065857,"o","\u001b[?2004l\u001b[?2004h\r\n>   const correctAnswer = String(progression[hiddenIndex]);"]
[353.5873236656189,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[353.58982276916504,"o","\u001b[?2004l\u001b[?2004h\r\n>   // Заменяем элемент на \"..\""]
[353.5923955440521,"o","\u001b[?2004l\u001b[?2004h\r\n>   progression[hiddenIndex] = '..';"]
[353.59324049949646,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[353.5943441390991,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.59843158721924,"o","  // Формируем вопрос (объединяем через пробел)"]
[353.6008520126343,"o","\u001b[?2004l\u001b[?2004h\r\n>   const question = progression.join(' ');"]
[353.60183095932007,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[353.60324811935425,"o","\u001b[?2004l\u001b[?2004h\r\n>   return {"]
[353.6049609184265,"o","\u001b[?2004l\u001b[?2004h\r\n>     question: question,"]
[353.60722613334656,"o","\u001b[?2004l\u001b[?2004h\r\n>     correctAnswer: correctAnswer,"]
[353.6082170009613,"o","\u001b[?2004l\u001b[?2004h\r\n>   };"]
[353.6090235710144,"o","\u001b[?2004l\u001b[?2004h\r\n> }"]
[353.60949659347534,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.6103172302246,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.61252546310425,"o","const gameRules = 'What number is missing in the progression?';"]
[353.612918138504,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[353.61467838287354,"o","\u001b[?2004l\u001b[?2004h\r\n> export default {"]
[353.61618065834045,"o","\u001b[?2004l\u001b[?2004h\r\n>   rules: gameRules,"]
[353.61859941482544,"o","\u001b[?2004l\u001b[?2004h\r\n>   generateRound: generateProgression,"]

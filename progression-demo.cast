[295.7753734588623,"o","import getRandomNumber from '../utils.js';"]
[295.77603363990784,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[295.77777099609375,"o","\u001b[?2004l\u001b[?2004h\r\n> function isPrime(num) {"]
[295.77916145324707,"o","\u001b[?2004l\u001b[?2004h\r\n>   if (num < 2) {"]
[295.7803268432617,"o","\u001b[?2004l\u001b[?2004h\r\n>     return false;"]
[295.7810277938843,"o","\u001b[?2004l\u001b[?2004h\r\n>   }"]
[295.78207206726074,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[295.7857129573822,"o","\u001b[?2004l\u001b[?2004h\r\n>   for (let i = 2; i <= Math.sqrt(num); i++) {"]
[295.787850856781,"o","\u001b[?2004l\u001b[?2004h\r\n>     if (num % i === 0) {"]
[295.78915095329285,"o","\u001b[?2004l\u001b[?2004h\r\n>       return false;"]
[295.79000902175903,"o","\u001b[?2004l\u001b[?2004h\r\n>     }"]
[295.79081106185913,"o","\u001b[?2004l\u001b[?2004h\r\n>   }"]
[295.79176115989685,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[295.79391407966614,"o","\u001b[?2004l\u001b[?2004h\r\n>   return true;"]
[295.79456615448,"o","\u001b[?2004l\u001b[?2004h\r\n> }"]
[295.79510498046875,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[295.79721236228943,"o","\u001b[?2004l\u001b[?2004h\r\n> function generateRound() {"]
[295.7975676059723,"o","\u001b[?2004l\r\n"]
[295.800479888916,"o","\u001b[?2004h>   const randomNumber = getRandomNumber(1, 100);"]
[295.80342292785645,"o","\u001b[?2004l\u001b[?2004h\r\n>   const correctAnswer = isPrime(randomNumber) ? 'yes' : 'no';"]
[295.80419301986694,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[3C"]
[295.8051254749298,"o","\u001b[?2004l\u001b[?2004h\r\n>   return {"]
[295.8073947429657,"o","\u001b[?2004l\u001b[?2004h\r\n>     question: String(randomNumber),"]
[295.8097114562988,"o","\u001b[?2004l\u001b[?2004h\r\n>     correctAnswer: correctAnswer,"]
[295.8105890750885,"o","\u001b[?2004l\u001b[?2004h\r\n>   };"]
[295.8114023208618,"o","\u001b[?2004l\u001b[?2004h\r\n> }"]
[295.81190395355225,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[295.8134319782257,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[295.8164119720459,"o","const gameRules = 'Answer \"yes\" if given number is prime. Otherwise answer \"no\".';"]
[295.8169460296631,"o","\u001b[?2004l\u001b[?2004h\r\n>\u001b[1C"]
[295.81854724884033,"o","\u001b[?2004l\u001b[?2004h\r\n> export default {"]
